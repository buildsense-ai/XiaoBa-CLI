# ==========================================
# 核心 LLM 配置
# ==========================================

# LLM 提供商（支持 openai / anthropic）
GAUZ_LLM_PROVIDER=anthropic
GAUZ_LLM_API_BASE=https://api.anthropic.com
GAUZ_LLM_API_KEY=your-api-key-here
GAUZ_LLM_MODEL=claude-sonnet-4-20250514

# LLM 备模型（可选，主模型失败时自动切换）
# 兼容写法1：无编号（只配1个备份时推荐）
GAUZ_LLM_BACKUP_PROVIDER=
GAUZ_LLM_BACKUP_API_BASE=
GAUZ_LLM_BACKUP_API_KEY=
GAUZ_LLM_BACKUP_MODEL=
# 兼容写法2：编号链路（支持多个备份）
# GAUZ_LLM_BACKUP_1_PROVIDER=
# GAUZ_LLM_BACKUP_1_API_BASE=
# GAUZ_LLM_BACKUP_1_API_KEY=
# GAUZ_LLM_BACKUP_1_MODEL=
# GAUZ_LLM_BACKUP_2_PROVIDER=
# GAUZ_LLM_BACKUP_2_API_BASE=
# GAUZ_LLM_BACKUP_2_API_KEY=
# GAUZ_LLM_BACKUP_2_MODEL=

# LLM 高级配置
GAUZ_LLM_FAILOVER_ON_ANY_ERROR=false
GAUZ_STREAM_FAILOVER_ON_PARTIAL=false
GAUZ_STREAM_RETRY=false
# GAUZ_LLM_MAX_PROMPT_TOKENS=120000

# 消息模式（basic / ultra，默认 ultra）
GAUZ_MESSAGE_MODE=ultra

# ==========================================
# 视觉模型配置
# ==========================================

GAUZ_VISION_PROVIDER=anthropic
GAUZ_VISION_API_BASE=https://api.anthropic.com
GAUZ_VISION_API_KEY=your-vision-api-key-here
GAUZ_VISION_MODEL=claude-sonnet-4-20250514

# 视觉备模型（可选）
GAUZ_VISION_BACKUP_PROVIDER=
GAUZ_VISION_BACKUP_API_BASE=
GAUZ_VISION_BACKUP_API_KEY=
GAUZ_VISION_BACKUP_MODEL=
# GAUZ_VISION_BACKUP_1_PROVIDER=
# GAUZ_VISION_BACKUP_1_API_BASE=
# GAUZ_VISION_BACKUP_1_API_KEY=
# GAUZ_VISION_BACKUP_1_MODEL=

# 视觉模型高级配置
GAUZ_VISION_RETRY_MAX=2
GAUZ_VISION_RETRY_BASE_SECONDS=1
GAUZ_VISION_FAILOVER_ON_ANY_ERROR=false

# ==========================================
# 安全配置
# ==========================================

# 工具白名单（逗号分隔，留空表示允许所有工具）
GAUZ_TOOL_ALLOW=

# 文件系统权限（默认开放，给 Agent 最大灵活性）
GAUZ_FS_ALLOW_OUTSIDE_READ=true
GAUZ_FS_ALLOW_OUTSIDE=true
GAUZ_FS_ALLOW_DOTENV=true

# Bash 命令权限
GAUZ_BASH_ALLOW_DANGEROUS=false

# ==========================================
# 飞书机器人配置
# ==========================================

FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_ALIASES=小八,xiaoba

# ==========================================
# Cats Company 平台配置
# ==========================================

CATSCOMPANY_SERVER_URL=ws://localhost:6061/v0/channels
CATSCOMPANY_API_KEY=your-catscompany-api-key

# ==========================================
# Bot Bridge 多 bot 协作配置
# ==========================================

BRIDGE_SECRET=
BOT_BRIDGE_NAME=
BOT_BRIDGE_PORT=
BOT_PEERS=
BOT_EXPERTISE=

# ==========================================
# 调试配置
# ==========================================

# 记录每轮完整 context window 到 logs/context-debug/
CONTEXT_DEBUG=true

# ==========================================
# PDF 解析配置
# ==========================================

# MinerU Token（用于 PDF 结构化解析）
MINERU_TOKEN=your-mineru-token-here

# MinIO 对象存储配置（MinerU 需要）
MINIO_ENDPOINT=your-minio-host:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=your-bucket-name
