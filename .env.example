# CatsCo local runtime configuration.
# Copy this file to .env when running from source. The packaged desktop app
# creates a user-local .env from this template on first launch.

# Main LLM provider. Supported values: anthropic, openai.
GAUZ_LLM_PROVIDER=anthropic
GAUZ_LLM_API_BASE=
GAUZ_LLM_API_KEY=
GAUZ_LLM_MODEL=

# CatsCo web connection.
# In the desktop app, the CatsCo page can fill these values after login/binding.
CATSCO_HTTP_BASE_URL=https://app.catsco.cc
CATSCO_SERVER_URL=wss://app.catsco.cc/v0/channels
CATSCO_API_KEY=
CATSCO_BOT_UID=
CATSCO_USER_TOKEN=
CATSCO_USER_UID=
CATSCO_USER_NAME=
CATSCO_USER_DISPLAY_NAME=

# Optional Feishu connector.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_ALIASES=CatsCo,catsco

# Optional Weixin connector.
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# Optional image reader proxy used by read_file for non-vision primary models.
READER_PROXY_URL=
READER_PROXY_API_KEY=
READER_PROXY_BEARER_TOKEN=

# CatsLog automatic session log upload. This reuses the local CatsCo login
# token, bootstraps a dedicated log-upload token, and uploads only
# logs/sessions/{chat,cli,catscompany,feishu,weixin}/YYYY-MM-DD/*.jsonl.
CATSCO_LOG_UPLOAD_ENABLED=true
CATSCO_LOG_API_BASE_URL=https://logs.catsco.fun:8000
CATSCO_LOG_UPLOAD_INTERVAL_MINUTES=30
CATSCO_LOG_STABLE_MINUTES=5
CATSCO_LOG_MAX_FILE_BYTES=26214400
CATSCO_LOG_MAX_FILES_PER_CYCLE=12
CATSCO_LOG_ROOT=logs
CATSCO_LOG_STATE_FILE=data/catsco-log-agent-state.json

# CatsCo Review Agent. This runs XiaoBa-CLI in a review role on the cloud
# computer. It reads only redacted /catsco/review/* data from Cloud Server A
# and writes proposal files for human review.
CATSCO_REVIEW_ENABLED=true
CATSCO_REVIEW_API_BASE_URL=https://logs.catsco.fun:8000
CATSCO_REVIEW_TOKEN=
CATSCO_REVIEW_OUTPUT_DIR=data/catsco-review-agent/runs
CATSCO_REVIEW_LOOKBACK_HOURS=24
CATSCO_REVIEW_INTERVAL_MINUTES=360
CATSCO_REVIEW_MAX_FAILURES=100
CATSCO_REVIEW_MAX_SESSIONS=30
CATSCO_REVIEW_MAX_ENTRIES_PER_SESSION=200
CATSCO_REVIEW_MAX_TURNS_PER_SESSION=80
CATSCO_REVIEW_TARGET_REPO=
CATSCO_REVIEW_PR_BASE_BRANCH=main
CATSCO_REVIEW_GIT_REMOTE=origin
CATSCO_REVIEW_CREATE_BRANCH=false
CATSCO_REVIEW_COMMIT_CHANGES=false
CATSCO_REVIEW_CREATE_GITHUB_PR=false

INSPECTOR_SERVER_URL=
INSPECTOR_SERVER_API_KEY=
XIAOBA_INSPECTOR_MAX_UPLOAD_BYTES=20971520
INSPECTOR_AUTO_UPLOAD_ENABLED=false
INSPECTOR_AUTO_UPLOAD_TIME=20:00
INSPECTOR_AUTO_UPLOAD_STABLE_MINUTES=5
INSPECTOR_AUTO_UPLOAD_MAX_FILES=12

# Bundled runtimes are prepared during Electron builds.
# You should not need to configure node/python/git paths here.
